{
  "name": "steamdeck-motion-cues",
  "version": "0.1.0",
  "description": "A Decky plugin that draws Steam Deck accelerometer-driven motion cue dots over games.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "rollup -c -w",
    "build:backend": "backend/build.sh",
    "test": "tsc --noEmit"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "motion-cues",
    "accelerometer"
  ],
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.6",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
